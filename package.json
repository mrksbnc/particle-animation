{
	"name": "@mrksbnc/particle-animation",
	"version": "1.0.0",
	"description": "Simple canvas-based particle animation written in TypeScript",
	"keywords": [
		"canvas",
		"creative-coding",
		"particle-animation"
	],
	"license": "MIT",
	"author": "Bence Markus",
	"main": "index.js",
	"scripts": {
		"build": "tsc --noEmit && node esbuild.config.mjs",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"lint": "oxlint --fix",
		"lint:spell": "cspell --config ./cspell.yaml \"**/*.{ts,html}\" --verbose",
		"typecheck": "tsc --noEmit",
		"dev": "pnpm build && open dist/index.html",
		"prepare": "husky"
	},
	"devDependencies": {
		"cspell": "^9.7.0",
		"esbuild": "^0.27.4",
		"husky": "^9.1.7",
		"oxfmt": "^0.42.0",
		"oxlint": "^1.56.0",
		"typescript": "^6.0.2"
	},
	"packageManager": "pnpm@10.32.1"
}